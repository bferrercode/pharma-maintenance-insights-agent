# Gemini API key (AI Studio) for local development.
# GOOGLE_GENAI_USE_VERTEXAI=False uses this key directly; set to True + configure
# GOOGLE_CLOUD_PROJECT/GOOGLE_CLOUD_LOCATION if you deploy to Vertex AI instead.
GOOGLE_API_KEY=your-google-api-key
GOOGLE_GENAI_USE_VERTEXAI=False

# Mock "SAP PM style" work-order export. Defaults to "OT SAP PM Demo.xlsx" in
# the project root if unset — only override if you rename/move the file.
WORKORDERS_PATH=OT SAP PM Demo.xlsx
WORKORDERS_SHEET_NAME=Hoja 1
